# Server
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite:///./notes_taker.db
DATABASE_URL_SYNC=sqlite:///./notes_taker.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1
FLOWER_PORT=5555

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
HASHING_ALGORITHM=bcrypt

# Local MLX Inference Server (Primary)
LOCAL_AI_BASE_URL=http://127.0.0.1:8085/v1
LOCAL_AI_API_KEY=omlx-yqha5fy1fm9aufeo
LOCAL_AI_MODEL=Qwen3.6-35B-A3B-UD-MLX-4bit

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]